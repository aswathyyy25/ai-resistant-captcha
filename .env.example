# .env.example

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Settings
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=3600

# CAPTCHA Settings
CAPTCHA_SECRET=your_captcha_secret_here
CAPTCHA_SITE_KEY=your_captcha_site_key_here
